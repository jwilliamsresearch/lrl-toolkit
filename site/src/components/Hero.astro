---
// Hero + animated WebGL galaxy whose "stars" are glyphs from world writing
// systems (a spiral of characters). The previous flat ASCII-globe hero is
// preserved in HeroGlobe.astro.
---
<section class="hero">
  <div class="hero-canvas-wrap" aria-hidden="true">
    <canvas id="galaxy-canvas"></canvas>
  </div>

  <div class="wrap hero-inner">
    <div class="hero-copy">
      <h1>Give <em>every</em> language<br />a model of its own.</h1>

      <p class="sub">
        A config-driven, open-source pipeline that takes <b>any</b> low-resource
        language, on <b>any</b> multilingual base model, from an ISO code to a
        fine-tuned, evaluated, publishable chat model on a single consumer GPU.
      </p>

      <div class="hero-cta">
        <a class="btn btn-primary" href="#quickstart">
          Get started
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a class="btn btn-ghost" href="https://github.com/jwilliamsresearch/lrl-toolkit">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38v-1.32c-2.23.48-2.7-1.08-2.7-1.08-.36-.92-.89-1.17-.89-1.17-.73-.5.06-.49.06-.49.8.06 1.23.83 1.23.83.71 1.23 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
          Star on GitHub
        </a>
      </div>

      <p class="hero-note"># ingest → clean → tokenizer → pretrain → convdata → finetune → evaluate → export</p>
    </div>
  </div>

  <a class="hero-scroll" href="#stats" aria-label="Scroll to details">
    <span></span>
  </a>
</section>

<section class="stats-section" id="stats">
  <div class="wrap">
    <div class="stats reveal">
      <div class="stat"><div class="n">33</div><div class="l">languages built-in</div></div>
      <div class="stat"><div class="n">21</div><div class="l">base models</div></div>
      <div class="stat"><div class="n">10</div><div class="l">data connectors</div></div>
      <div class="stat"><div class="n">8</div><div class="l">pipeline stages</div></div>
      <div class="stat"><div class="n">1</div><div class="l">YAML to add a language</div></div>
    </div>
  </div>
</section>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('galaxy-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- glyph atlas: one texture holding characters from many scripts ------
    const GLYPHS = (
      'lrltoolkÿŵŷâêîôûçşñ' +               // Latin (Welsh, Kurdish, Cornish)
      'ابپتجچحخدرزسشعفقکگلمنوهیێۆ' +        // Arabic (Kurdish, Farsi, Pashto, Uyghur)
      'ሀለመረሰቀበተነአከወየደገ' +                  // Ge'ez (Amharic)
      'ཀཁགངཅཇཏདནཔབམ' +                     // Tibetan
      'бвгджзиклмнпрс' +                    // Cyrillic (Mongolian)
      'कखगचजटतदनपबमयरलवशस' +                // Devanagari (Nepali)
      'កខគងចជតនបពមយរលសហ' +                  // Khmer
      '文语'                                // echo the logo
    ).split('');
    const COLS = 8, ROWS = 8, CELL = 64;   // 64 cells, 512x512 atlas
    const atlas = document.createElement('canvas');
    atlas.width = COLS * CELL;
    atlas.height = ROWS * CELL;
    const actx = atlas.getContext('2d')!;
    actx.fillStyle = '#fff';
    actx.textAlign = 'center';
    actx.textBaseline = 'middle';
    actx.font = `${Math.floor(CELL * 0.66)}px "Noto Sans", ui-monospace, "JetBrains Mono", Menlo, sans-serif`;
    const NGLYPH = COLS * ROWS;
    for (let i = 0; i < NGLYPH; i++) {
      const g = GLYPHS[i % GLYPHS.length];
      const cx = (i % COLS) * CELL + CELL / 2;
      const cy = ((i / COLS) | 0) * CELL + CELL / 2;
      actx.fillText(g, cx, cy);
    }
    const atlasTex = new THREE.CanvasTexture(atlas);
    atlasTex.flipY = false; // match canvas top-left origin to gl_PointCoord
    atlasTex.minFilter = THREE.LinearFilter;
    atlasTex.magFilter = THREE.LinearFilter;

    let renderer: THREE.WebGLRenderer;
    try {
      renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true, powerPreference: 'high-performance' });
    } catch (e) {
      throw e; // no WebGL: leave the canvas blank, page bg shows through
    }
    const PR = Math.min(2, window.devicePixelRatio || 1);
    renderer.setPixelRatio(PR);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(58, 1, 0.1, 100);
    camera.position.set(0, 2.75, 5.1);
    camera.lookAt(0, 0, 0);

    // ---- galaxy geometry: a spiral of glyph "stars" -------------------------
    const RADIUS = 5, BRANCHES = 4, SPIN = 0.85, RANDOMNESS = 0.55, RAND_POW = 2.6;
    const mobile = window.innerWidth < 760;
    const COUNT = mobile ? 5200 : 11000;

    const positions = new Float32Array(COUNT * 3);
    const radii = new Float32Array(COUNT);
    const aGlyph = new Float32Array(COUNT);
    const aScale = new Float32Array(COUNT);
    for (let i = 0; i < COUNT; i++) {
      const i3 = i * 3;
      const radius = Math.pow(Math.random(), 1.5) * RADIUS;
      radii[i] = radius;
      const branch = ((i % BRANCHES) / BRANCHES) * Math.PI * 2;
      const spin = radius * SPIN;
      const rp = () => Math.pow(Math.random(), RAND_POW) * (Math.random() < 0.5 ? 1 : -1) * RANDOMNESS * radius;
      positions[i3] = Math.cos(branch + spin) * radius + rp();
      positions[i3 + 1] = rp() * 0.45;
      positions[i3 + 2] = Math.sin(branch + spin) * radius + rp();
      aGlyph[i] = (Math.random() * NGLYPH) | 0;
      aScale[i] = 0.55 + Math.random() * 0.9;
    }

    const geometry = new THREE.BufferGeometry();
    geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    geometry.setAttribute('aColor', new THREE.BufferAttribute(new Float32Array(COUNT * 3), 3));
    const glyphAttr = new THREE.BufferAttribute(aGlyph, 1);
    geometry.setAttribute('aGlyph', glyphAttr);
    geometry.setAttribute('aScale', new THREE.BufferAttribute(aScale, 1));

    const material = new THREE.ShaderMaterial({
      transparent: true,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
      uniforms: {
        uAtlas: { value: atlasTex },
        uCols: { value: COLS },
        uRows: { value: ROWS },
        uSize: { value: 78 * PR },
        uOpacity: { value: 1 },
      },
      vertexShader: `
        attribute float aGlyph;
        attribute float aScale;
        attribute vec3 aColor;
        varying vec3 vColor;
        varying float vGlyph;
        uniform float uSize;
        void main() {
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          gl_Position = projectionMatrix * mv;
          gl_PointSize = uSize * aScale / max(0.1, -mv.z);
          vColor = aColor;
          vGlyph = aGlyph;
        }`,
      fragmentShader: `
        precision mediump float;
        uniform sampler2D uAtlas;
        uniform float uCols, uRows, uOpacity;
        varying vec3 vColor;
        varying float vGlyph;
        void main() {
          vec2 cell = vec2(mod(vGlyph, uCols), floor(vGlyph / uCols));
          vec2 uv = (cell + gl_PointCoord) / vec2(uCols, uRows);
          float a = texture2D(uAtlas, uv).a * uOpacity;
          if (a < 0.03) discard;
          gl_FragColor = vec4(vColor, a);
        }`,
    });

    // Theme-reactive colours: additive teal→indigo glow on dark; saturated,
    // normally-blended colours that read on a light background.
    function applyTheme() {
      const light = document.documentElement.getAttribute('data-theme') === 'light';
      const inside = new THREE.Color(light ? '#0d9488' : '#d3fff5');
      const outside = new THREE.Color(light ? '#4338ca' : '#4326c0');
      const col = geometry.getAttribute('aColor') as THREE.BufferAttribute;
      const tmp = new THREE.Color();
      for (let i = 0; i < COUNT; i++) {
        tmp.copy(inside).lerp(outside, Math.min(1, radii[i] / RADIUS));
        col.setXYZ(i, tmp.r, tmp.g, tmp.b);
      }
      col.needsUpdate = true;
      material.blending = light ? THREE.NormalBlending : THREE.AdditiveBlending;
      material.uniforms.uOpacity.value = light ? 0.9 : 1;
    }
    applyTheme();

    const spinner = new THREE.Points(geometry, material);
    const galaxy = new THREE.Group();
    galaxy.add(spinner);
    galaxy.rotation.x = 0.18;
    scene.add(galaxy);

    function layout() {
      const rect = canvas!.getBoundingClientRect();
      const w = Math.max(1, rect.width), h = Math.max(1, rect.height);
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      galaxy.position.x = w < 760 ? 0 : 1.5;
    }
    layout();

    // gentle pointer parallax
    let px = 0, py = 0, tx = 0, ty = 0;
    if (!reduce) {
      window.addEventListener('pointermove', (e) => {
        tx = (e.clientX / window.innerWidth - 0.5) * 0.5;
        ty = (e.clientY / window.innerHeight - 0.5) * 0.35;
      }, { passive: true });
    }

    // occasionally re-roll a few glyphs so the field subtly shimmers/morphs
    let morphTick = 0;
    function morph() {
      for (let k = 0; k < 40; k++) {
        aGlyph[(Math.random() * COUNT) | 0] = (Math.random() * NGLYPH) | 0;
      }
      glyphAttr.needsUpdate = true;
    }

    const clock = new THREE.Clock();
    let raf = 0;
    function frame() {
      const dt = clock.getDelta();
      spinner.rotation.y += dt * 0.07;
      px += (tx - px) * 0.04;
      py += (ty - py) * 0.04;
      camera.position.x = px * 2;
      camera.position.y = 2.75 + py * 1.5;
      camera.lookAt(galaxy.position.x * 0.5, 0, 0);
      if (++morphTick % 6 === 0) morph();
      renderer.render(scene, camera);
      raf = requestAnimationFrame(frame);
    }
    function start() { if (!raf) { clock.getDelta(); raf = requestAnimationFrame(frame); } }
    function stop() { cancelAnimationFrame(raf); raf = 0; }

    if (reduce) renderer.render(scene, camera);
    else start();

    const ro = new ResizeObserver(() => { layout(); if (reduce) renderer.render(scene, camera); });
    ro.observe(canvas);

    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (reduce) return;
        if (e.isIntersecting) start(); else stop();
      }
    }, { threshold: 0 });
    io.observe(canvas);

    const mo = new MutationObserver(() => { applyTheme(); if (reduce) renderer.render(scene, camera); });
    mo.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  }
</script>
