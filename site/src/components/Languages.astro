---
const groups = [
  {
    label: 'Celtic',
    langs: [
      { g: 'ŵ', n: 'Welsh' }, { g: 'á', n: 'Irish' }, { g: 'à', n: 'Scottish Gaelic' },
      { g: 'ñ', n: 'Breton' }, { g: 'ᴋ', n: 'Cornish' },
    ],
  },
  {
    label: 'African',
    langs: [
      { g: 'ki', n: 'Swahili' }, { g: 'ọ', n: 'Yoruba' }, { g: 'ɗ', n: 'Hausa' },
      { g: 'አ', n: 'Amharic' }, { g: 'ɓ', n: 'Zulu' }, { g: 'x', n: 'Xhosa' },
    ],
  },
  {
    label: 'Asian',
    langs: [
      { g: 'ئ', n: 'Uyghur' }, { g: 'ཀ', n: 'Tibetan' }, { g: 'پ', n: 'Pashto' },
      { g: 'क', n: 'Nepali' }, { g: 'ក', n: 'Khmer' }, { g: 'ᠮ', n: 'Mongolian' },
    ],
  },
  {
    label: 'Kurdish',
    langs: [
      { g: 'ç', n: 'Kurmanji' }, { g: 'ک', n: 'Sorani' },
    ],
  },
];

const models = [
  'Qwen2.5 · 0.5–7B', 'Llama 3.1', 'Llama 3.2', 'Gemma 2', 'Mistral',
  'Phi-3.5', 'Aya-23', 'Aya-Expanse', 'BLOOMZ', 'SmolLM2', 'TinyLlama', 'XLM-R',
];

const connectors = [
  'Wikipedia', 'Glot500', 'CulturaX', 'MADLAD-400', 'OSCAR',
  'Common Crawl', 'OPUS / NLLB', 'SMOL', 'local',
];
---
<section class="section" id="languages">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">Not just the presets</span>
      <h2>Any language. Any base model.</h2>
      <p>The toolkit works for <b>any</b> low-resource language on <b>any</b> multilingual base — point it at any Hugging Face model. To make that easy, <b>33 languages</b> and <b>19 base models</b> ship built-in with script &amp; dialect metadata, NLLB codes, and source catalogs. Add your own by dropping a YAML in <code style="font-family:var(--font-mono);color:var(--accent)">configs/</code>.</p>
    </div>

    <div class="langs-grid">
      <div class="lang-card reveal">
        <h3>Built-in languages <span class="badge">33 · or any</span></h3>
        {groups.map((grp) => (
          <div class="lang-group">
            <div class="gl">{grp.label}</div>
            <div class="chips">
              {grp.langs.map((l) => (
                <span class="chip"><span class="glyph">{l.g}</span>{l.n}</span>
              ))}
            </div>
          </div>
        ))}
        <div class="lang-group">
          <div class="chips">
            <span class="chip more">+ Farsi, Somali, Sinhala, Occitan, Maltese, Quechua &amp; more</span>
          </div>
        </div>
      </div>

      <div style="display:flex;flex-direction:column;gap:22px">
        <div class="lang-card reveal">
          <h3>Base models <span class="badge">19 · or any</span></h3>
          <div class="chips">
            {models.map((m) => <span class="chip">{m}</span>)}
            <span class="chip more">…or any multilingual HF model</span>
          </div>
        </div>
        <div class="lang-card reveal">
          <h3>Data connectors <span class="badge">9</span></h3>
          <div class="chips">
            {connectors.map((c) => <span class="chip">{c}</span>)}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
